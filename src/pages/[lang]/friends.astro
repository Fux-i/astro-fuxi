---
import Layout from "@/layouts/Layout.astro";
import { getT } from "@/i18n/ui";
import { getSingle } from "@/content";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "zh" } }];
}
const { lang, t } = getT(Astro.currentLocale);
const doc = getSingle("friends", lang);
const friends = (doc?.frontmatter.friends ?? []) as Array<{
  name: string;
  tag: string;
  url: string;
  motto: string;
  avatar: string;
}>;
---

<Layout title={t("nav.friends") + t("site.title_suffix")} desc="">
  <h1>{t("nav.friends")}</h1>
  <ul>
    {
      friends.map((f) => (
        <li>
          <a href={f.url} target="_blank" rel="noopener noreferrer">
            {f.name}
          </a>
          {f.tag && <span> — {f.tag}</span>}
          {f.motto && <p>{f.motto}</p>}
        </li>
      ))
    }
  </ul>
</Layout>
