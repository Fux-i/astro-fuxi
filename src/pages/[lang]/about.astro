---
import Layout from "@/layouts/Layout.astro";
import { getT } from "@/i18n/ui";
import { getSingle } from "@/content";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "zh" } }];
}
const { lang, t } = getT(Astro.currentLocale);
const doc = getSingle("about", lang);
---

<Layout title={t("nav.about") + t("site.title_suffix")} desc="">
  {doc ? <doc.Content /> : <p>Not found.</p>}
</Layout>
