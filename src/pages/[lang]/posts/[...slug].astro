---
import Layout from "@/layouts/Layout.astro";
import Article from "@/components/common/Article.astro";
import { getCollection, type CollectionItem } from "@/content";
import type { Lang } from "@/i18n/ui";

export function getStaticPaths() {
  const langs: Lang[] = ["en", "zh"];
  return langs.flatMap((lang) =>
    getCollection("posts", lang).map((p) => ({
      params: { lang, slug: p.slug },
      props: { item: p },
    })),
  );
}

const { item } = Astro.props as { item: CollectionItem };
const { frontmatter } = item;
---

<Layout title={frontmatter.title ?? item.slug} desc={frontmatter.desc ?? ""}>
  <Article item={item} exclusive={true} />
</Layout>
