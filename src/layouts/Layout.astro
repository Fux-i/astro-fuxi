---
import BaseHead from "@/components/common/BaseHead.astro";

interface Props {
  title: string;
  desc: string;
  image?: ImageMetadata;
}

let { title, desc, image = undefined } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} desc={desc} image={image} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
