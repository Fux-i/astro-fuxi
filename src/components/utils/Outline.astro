---
import IconOutline from "@/assets/icons/iconOutline.svg";
import { getT } from "@/i18n/ui";
import type { MarkdownHeading } from "@/content";

const { t } = getT(Astro.currentLocale);
interface Props {
  toc: MarkdownHeading[];
}

const { toc } = Astro.props;
const HEADING_LINE_HEIGHT = 1.25;
const ITEM_GAP = 0.375;
const INDENT_STEP = 1;
const BASE_DOT_X = 0.4;
const LINK_GAP = 0.85;
const SVG_SCALE = 100;

function formatRem(value: number): string {
  return `${Number(value.toFixed(3))}rem`;
}

function dotSize(depth: number): number {
  if (depth <= 2) return 0.45;
  if (depth === 3) return 0.36;
  return 0.28;
}

function dotX(depth: number): number {
  return BASE_DOT_X + (depth - 2) * INDENT_STEP;
}

const headings = (toc ?? []).filter((h) => h.depth >= 2 && h.depth <= 6);
const items = headings.map((h, index) => {
  const next = headings[index + 1];
  const size = dotSize(h.depth);
  const x = dotX(h.depth);
  const nextSize = next ? dotSize(next.depth) : size;
  const nextX = next ? dotX(next.depth) : x;
  const connectorHeight =
    HEADING_LINE_HEIGHT + ITEM_GAP - (size + nextSize) / 2;
  const connectorLeft = Math.min(x, nextX);
  const connectorWidth = Math.abs(nextX - x);
  const svgWidth = Math.max(connectorWidth, 0.001) * SVG_SCALE;
  const svgHeight = connectorHeight * SVG_SCALE;
  const startX = (x - connectorLeft) * SVG_SCALE;
  const endX = (nextX - connectorLeft) * SVG_SCALE;

  return {
    ...h,
    dotSize: formatRem(size),
    dotX: formatRem(x),
    paddingStart: formatRem(x + LINK_GAP),
    connector: next
      ? {
          sameDepth: h.depth === next.depth,
          left: formatRem(connectorLeft),
          width: formatRem(connectorWidth),
          height: formatRem(connectorHeight),
          viewBox: `0 0 ${svgWidth} ${svgHeight}`,
          path: `M ${startX} 0 C ${startX} ${svgHeight * 0.45}, ${endX} ${svgHeight * 0.55}, ${endX} ${svgHeight}`,
        }
      : null,
  };
});
---

<outline-box class="outline-box relative block shrink-0 open">
  <button
    type="button"
    title={t("btn.outline")}
    class="outline-toggle grid place-items-center size-10 rounded-full bg-(--article-bg) shadow cursor-pointer hover:brightness-90"
  >
    <IconOutline class="size-4" />
  </button>

  {
    items.length > 0 && (
      <nav class="outline-nav relative mt-2 hidden p-3">
        <ol class="outline-list relative space-y-1.5 text-sm">
          {items.map((h) => (
            <li
              class="outline-item relative"
              data-slug={h.slug}
              style={`--dot-size:${h.dotSize};--dot-x:${h.dotX};padding-inline-start:${h.paddingStart}`}
            >
              {h.connector && (
                <span
                  class:list={[
                    "outline-connector",
                    h.connector.sameDepth ? "is-straight" : "is-curved",
                  ]}
                  style={`--connector-left:${h.connector.left};--connector-width:${h.connector.width};--connector-height:${h.connector.height}`}
                  aria-hidden="true"
                >
                  {!h.connector.sameDepth && (
                    <svg
                      viewBox={h.connector.viewBox}
                      preserveAspectRatio="none"
                    >
                      <path d={h.connector.path} />
                    </svg>
                  )}
                </span>
              )}
              <a
                href={`#${h.slug}`}
                class="outline-link block truncate opacity-70 hover:opacity-100"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )
  }
</outline-box>

<style>
  .outline-list {
    --dot-center-y: 0.75rem;
    --outline-line-height: 1.25rem;
  }
  .outline-item::before {
    content: "";
    position: absolute;
    z-index: 1;
    left: calc(var(--dot-x) - var(--dot-size) / 2);
    top: calc(var(--dot-center-y) - var(--dot-size) / 2);
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 9999px;
    background: currentColor;
  }
  .outline-item {
    min-height: var(--outline-line-height);
    line-height: var(--outline-line-height);
  }
  .outline-connector {
    position: absolute;
    top: calc(var(--dot-center-y) + var(--dot-size) / 2);
    left: var(--connector-left);
    height: var(--connector-height);
    color: currentColor;
    opacity: 0.2;
    pointer-events: none;

    &.is-straight {
      width: 0;
      border-left: 1px solid currentColor;
    }

    &.is-curved {
      width: var(--connector-width);

      svg {
        display: block;
        width: 100%;
        height: 100%;
        overflow: visible;
      }

      path {
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-width: 1px;
        vector-effect: non-scaling-stroke;
      }
    }
  }
  .outline-link {
    position: relative;
    z-index: 1;
  }
  .outline-item.active::before {
    background: var(--accent, #2563eb);
    opacity: 1;
  }
  .outline-item.active > .outline-link {
    color: var(--accent, #2563eb);
    font-weight: 600;
    opacity: 1;
  }
  .outline-box.open .outline-nav {
    display: block;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".outline-toggle")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        btn.closest(".outline-box")?.classList.toggle("open");
      });
    });

  document.querySelectorAll<HTMLElement>(".outline-box").forEach((box) => {
    const article = box.closest(".article-wrapper")?.querySelector(".article");
    if (!article) return;
    const headings = article.querySelectorAll<HTMLElement>(
      "h2[id], h3[id], h4[id], h5[id], h6[id]",
    );
    if (!headings.length) return;

    const update = () => {
      const threshold = window.innerHeight * 0.25;
      let cur: HTMLElement | null = null;
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= threshold) cur = h;
        else break;
      }
      box.querySelector(".outline-item.active")?.classList.remove("active");
      if (cur) {
        box
          .querySelector(`.outline-item[data-slug="${cur.id}"]`)
          ?.classList.add("active");
      }
    };

    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        raf = 0;
        update();
      });
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    update();
  });
</script>
