---
import IconOutline from "@/assets/icons/iconOutline.svg";
import { getT } from "@/i18n/ui";
import type { MarkdownHeading } from "@/content";
import { buildOutlineItems } from "./outline-items";

const { t } = getT(Astro.currentLocale);
interface Props {
  toc: MarkdownHeading[];
}

const { toc } = Astro.props;
const items = buildOutlineItems(toc);
---

<outline-box class="outline-box relative block shrink-0 open">
  <button
    type="button"
    title={t("btn.outline")}
    aria-expanded="true"
    class="outline-toggle grid place-items-center size-10 rounded-full bg-(--article-bg) shadow cursor-pointer hover:brightness-90"
  >
    <IconOutline class="size-4" />
  </button>

  {
    items.length > 0 && (
      <nav class="outline-nav relative mt-2 hidden p-3">
        <ol class="outline-list relative space-y-1.5 text-sm">
          {items.map((h) => (
            <li
              class="outline-item relative"
              data-anchor={h.slug}
              style={`--dot-size:${h.dotSize};--dot-x:${h.dotX};padding-inline-start:${h.paddingStart}`}
            >
              {h.connector && (
                <span
                  class:list={[
                    "outline-connector",
                    h.connector.sameDepth ? "is-straight" : "is-curved",
                  ]}
                  style={`--connector-left:${h.connector.left};--connector-width:${h.connector.width};--connector-height:${h.connector.height}`}
                  aria-hidden="true"
                >
                  {!h.connector.sameDepth && (
                    <svg
                      viewBox={h.connector.viewBox}
                      preserveAspectRatio="none"
                    >
                      <path d={h.connector.path} />
                    </svg>
                  )}
                </span>
              )}
              <a
                href={`#${h.slug}`}
                class="outline-link block truncate opacity-70 hover:opacity-100"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )
  }
</outline-box>

<style>
  .outline-box {
    --outline-panel-width: min(18rem, calc(100vw - 2rem));
    width: max-content;
    max-width: var(--outline-panel-width);
  }
  .outline-nav {
    width: max-content;
    max-width: var(--outline-panel-width);
    max-height: calc(100vh - 7rem);
    overflow: auto;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    transition:
      transform 200ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease;
  }
  .outline-list {
    min-width: min(12rem, calc(100vw - 2rem));
    --dot-center-y: 0.75rem;
    --outline-line-height: 1.25rem;
  }
  .outline-item::before {
    content: "";
    position: absolute;
    z-index: 1;
    left: calc(var(--dot-x) - var(--dot-size) / 2);
    top: calc(var(--dot-center-y) - var(--dot-size) / 2);
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 9999px;
    background: currentColor;
  }
  .outline-item {
    min-height: var(--outline-line-height);
    line-height: var(--outline-line-height);
  }
  .outline-connector {
    position: absolute;
    top: calc(var(--dot-center-y) + var(--dot-size) / 2);
    left: var(--connector-left);
    height: var(--connector-height);
    color: currentColor;
    opacity: 0.2;
    pointer-events: none;

    &.is-straight {
      width: 0;
      border-left: 1px solid currentColor;
    }

    &.is-curved {
      width: var(--connector-width);

      svg {
        display: block;
        width: 100%;
        height: 100%;
        overflow: visible;
      }

      path {
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-width: 1px;
        vector-effect: non-scaling-stroke;
      }
    }
  }
  .outline-link {
    position: relative;
    z-index: 1;
  }
  .outline-item.active::before {
    background: var(--accent, #2563eb);
    opacity: 1;
  }
  .outline-item.active > .outline-link {
    color: var(--accent, #2563eb);
    font-weight: 600;
    opacity: 1;
  }
  .outline-box.open .outline-nav {
    display: block;
  }
  :global(.outline-edge) .outline-box.is-peeking .outline-nav,
  :global(.outline-inset) .outline-box.open .outline-nav {
    border-color: color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, var(--article-bg) 82%, transparent);
    box-shadow: 0 0.75rem 2rem color-mix(in srgb, black 14%, transparent);
    backdrop-filter: blur(0.75rem);
  }
  :global(.outline-edge) .outline-box.is-peeking .outline-nav {
    transform: translateX(var(--outline-shift, 0px));
  }
  :global(.outline-inset) .outline-box {
    width: 100%;
    max-width: none;
  }
  :global(.outline-inset) .outline-toggle {
    margin-inline-start: auto;
  }
  :global(.outline-inset) .outline-nav {
    width: 100%;
    max-width: none;
  }
</style>

<script>
  import { initOutline } from "./outline-client";

  initOutline();
</script>
