---
import { type CollectionItem } from "@/content";
import { SITE } from "@/config";
import { getT } from "@/i18n/ui";
import Outline from "../utils/Outline.astro";

interface Props {
  item: CollectionItem;
  exclusive: boolean;
}

const { item, exclusive } = Astro.props;
const { Content, frontmatter } = item;
const { t } = getT(Astro.currentLocale);

const page_width = "max-w-" + SITE.page_width;

const publishedAt = frontmatter["published-at"];
const updatedAt = frontmatter["updated-at"];
const tags: string[] = frontmatter.tags ?? [];
const hasMeta = publishedAt || updatedAt || tags.length > 0;
---

<div
  class:list={[
    page_width,
    "article-wrapper relative mx-auto shadow",
    !exclusive && "collapsible my-4",
  ]}
>
  <article
    class:list={[
      "article bg-(--article-bg) px-8 py-4",
      !exclusive && "h-64 overflow-hidden transition-[height] duration-300 sm:h-48",
    ]}
  >
    {
      exclusive ? (
        <h1 id={item.slug}>{frontmatter.title ?? item.slug}</h1>
      ) : (
        <a
          href={item.slug}
          class:list={"title-a text-xl transition-[font-size] duration-300"}
        >
          <b>{frontmatter.title ?? item.slug}</b>
        </a>
      )
    }
    {
      hasMeta && (
        <post-meta class="my-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
          {(publishedAt || updatedAt) && (
            <span class="min-w-0">
              {publishedAt && (
                <span>
                  {t("article.published_at")}{" "}
                  <time datetime={publishedAt}>{publishedAt}</time>
                </span>
              )}
              {updatedAt && (
                <span>
                  {t("article.updated_at")}{" "}
                  <time datetime={updatedAt}>{updatedAt}</time>
                </span>
              )}
            </span>
          )}
          {tags.length > 0 && (
            <tag-list class="flex flex-wrap items-center gap-2">
              {tags.map((tag) => (
                <post-tag class="shrink-0 whitespace-nowrap border border-gray-200 px-2 py-0.5 text-xs text-gray-600 dark:border-gray-600 dark:text-gray-300">
                  {tag}
                </post-tag>
              ))}
            </tag-list>
          )}
        </post-meta>
      )
    }
    <Content />
  </article>
  <sticky-rail
    class:list={[
      "sticky-rail absolute inset-y-0 -right-4 z-20 w-0 transition-opacity duration-300",
      exclusive
        ? "pointer-events-auto opacity-100"
        : "pointer-events-none opacity-0",
    ]}
  >
    <div class="sticky top-20 flex gap-2">
      <Outline toc={item.headings} />
      {
        !exclusive && (
          <button
            type="button"
            title={t("article.collapse")}
            class="absolute left-13 collapse-btn grid size-10 shrink-0 cursor-pointer place-items-center rounded-full bg-(--article-bg) shadow hover:brightness-90"
          >
            ⏶
          </button>
        )
      }
    </div>
  </sticky-rail>
  {
    !exclusive && (
      <div class="fade-mask absolute inset-x-0 bottom-0 h-35 cursor-pointer transition-opacity duration-300">
        <p class="text-blue-500 text-center w-full absolute bottom-2">
          {t("article.expand")}
        </p>
      </div>
    )
  }
</div>

<style>
  .fade-mask {
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--article-bg) 0%, transparent),
      var(--article-bg)
    );
  }
  .collapsible.expanded > article {
    height: calc-size(auto, size);
  }
  .expanded .fade-mask {
    opacity: 0;
    pointer-events: none;
  }
  .expanded .sticky-rail {
    opacity: 1;
    pointer-events: auto;
  }
  :global(html),
  :global(body) {
    overflow-x: clip;
  }
  .outline-inset .sticky-rail {
    inset: 1rem 1rem 0 auto;
    width: min(18rem, calc(100% - 2rem));
  }
  .outline-inset .sticky-rail > .sticky {
    top: 5rem;
    width: 100%;
    transform: none;
  }
  .outline-inset .outline-box {
    width: 100%;
  }
  .outline-inset .outline-toggle {
    margin-inline-start: auto;
  }
  .outline-inset .collapse-btn {
    right: 3.25rem;
    left: auto;
  }
  .expanded {
    a.title-a {
      font-size: 2rem;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".fade-mask").forEach((mask) => {
    mask.addEventListener("click", () => {
      mask.closest(".article-wrapper")?.classList.add("expanded");
      window.dispatchEvent(new CustomEvent("article-layout-change"));
    });
  });
  document
    .querySelectorAll<HTMLButtonElement>(".collapse-btn")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        btn.closest(".article-wrapper")?.classList.remove("expanded");
        window.dispatchEvent(new CustomEvent("article-layout-change"));
      });
    });
</script>
